<!-- RPG-7 -->
  <ThingDef ParentName="GOGWeaponGun">
    <defName>MWII_Gun_RPG7_LCH</defName>
    <label>RPG-7</label>
    <description>A reusable launcher that fires unguided rockets, relying on operator aim rather than onboard guidance. Its simple construction and variety of warheads allow it to engage armored targets and fortified positions with direct, high-impact strikes.</description>
    <graphicData>
      <texPath>Things/Weapons/RPG7</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.17</drawSize>
    </graphicData>
	<equippedStatOffsets>
     <MoveSpeed>-0.3</MoveSpeed>
	</equippedStatOffsets>
    <soundInteract>MWP_Interact_PILA</soundInteract>
	<techLevel>Industrial</techLevel>
<thingCategories>
    <li>MWP_ThingCategory_LCH</li>
  </thingCategories>
    <statBases>
      <WorkToMake>24000</WorkToMake>
      <Mass>3.8</Mass>
      <AccuracyTouch>0.2</AccuracyTouch>
      <AccuracyShort>0.4</AccuracyShort>
      <AccuracyMedium>0.6</AccuracyMedium>
      <AccuracyLong>0.6</AccuracyLong>
      <RangedWeapon_Cooldown>4.5</RangedWeapon_Cooldown>
    </statBases>
<recipeMaker>
  <researchPrerequisite>GOG_Research_ATSystems</researchPrerequisite>
  <skillRequirements>
    <Crafting>7</Crafting>
  </skillRequirements>
  <recipeUsers Inherit="False">
    <li>TableMachining</li>
  </recipeUsers>
</recipeMaker>
<smeltable>true</smeltable>
<costList>
    <Steel>55</Steel>
    <WoodLog>40</WoodLog>
    <ComponentIndustrial>4</ComponentIndustrial>
  </costList>

    <verbs>
      <li>
	<verbClass>Verb_LaunchProjectile</verbClass>
	<hasStandardCommand>true</hasStandardCommand>
	<defaultProjectile>RPG_Rocket</defaultProjectile>
	<forcedMissRadius>2.9</forcedMissRadius>
	<warmupTime>4.25</warmupTime>
	<range>32</range>
	<soundCast>MWP_Shot_RPG7</soundCast>
	<soundCastTail>GunTail_Heavy</soundCastTail>
	<targetParams>
	<canTargetLocations>true</canTargetLocations>
	</targetParams>
	<muzzleFlashScale>14</muzzleFlashScale>
	  </li>
    </verbs>

    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>1.2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>7</power>
        <cooldownTime>1.3</cooldownTime>
      </li>
    </tools>
    <weaponTags>
      <li>GunSingleUse</li>
      <li>IndustrialGunAdvanced</li>
	  <li>IndustrialGun</li>
	  <li>MWP</li>
      <li>MWPRUS</li>
      <li>MWPUKR</li>
      <li>MWPCHA</li>
      <li>MWPNEUTRAL</li>
      <li>MWPINSURGENT</li>
    </weaponTags>

  </ThingDef>

